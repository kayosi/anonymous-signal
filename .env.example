# Anonymous Signal — Environment Configuration
# ============================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
#
# Generate secrets:
#   ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   JWT_SECRET:     openssl rand -hex 32
#   PASSWORDS:      openssl rand -base64 24

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=anon_signal
POSTGRES_USER=anon_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_IN_PROD

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ─── Encryption (CRITICAL) ───────────────────────────────────────────────────
# All report content is encrypted with this key.
# Losing this key = losing all report content. Back it up securely.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERATE_32_BYTE_FERNET_KEY_HERE

# ─── Auth (CRITICAL) ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=GENERATE_STRONG_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRE_MINUTES=1440

# ─── AI Models ───────────────────────────────────────────────────────────────
# Whisper model size (tradeoff: accuracy vs speed vs memory)
# tiny=fastest/least accurate, base=balanced, small=good, medium=better, large=best
WHISPER_MODEL=base

# Classification model (zero-shot NLI)
CLASSIFICATION_MODEL=facebook/bart-large-mnli

# Embedding model (clustering)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Service URLs ─────────────────────────────────────────────────────────────
# Internal Docker network URLs (do not expose externally)
AI_SERVICE_URL=http://ai-service:8001
BACKEND_URL=http://backend:8000

# ─── Dashboard (Next.js) ──────────────────────────────────────────────────────
# Public URL of the backend API (used by dashboard frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Environment ─────────────────────────────────────────────────────────────
# Options: development | production | testing
ENVIRONMENT=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API
# Example: https://dashboard.yourplatform.gov
CORS_ORIGINS=http://localhost:3000

# ─── Upload Limits ────────────────────────────────────────────────────────────
MAX_AUDIO_SIZE_MB=10
MAX_IMAGE_SIZE_MB=5

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_SUBMISSIONS=10
RATE_LIMIT_WINDOW_SECONDS=300

# ─── Intelligence Scheduler ───────────────────────────────────────────────────
# How often (seconds) to run the background intelligence scan
SCHEDULER_INTERVAL_SECONDS=300

# ─── Privacy Settings (DO NOT CHANGE — Hardcoded to protect anonymity) ────────
DISABLE_ACCESS_LOGS=true
STORE_IP_ADDRESSES=false
STORE_USER_AGENTS=false
